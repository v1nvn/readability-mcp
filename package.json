{
  "name": "readability-mcp",
  "version": "0.1.0",
  "description": "MCP server that turns rendered (post-JS) HTML into clean Markdown + metadata via Readability, Turndown, and DOMPurify.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "readability-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update-goldens": "UPDATE_GOLDENS=1 vitest run",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "readability",
    "markdown",
    "turndown",
    "model-context-protocol"
  ],
  "author": "v1nvn",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "dompurify": "^3.4.12",
    "jsdom": "^29.1.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^26.1.0",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
